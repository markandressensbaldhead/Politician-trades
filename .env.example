# QuiverQuant
QUIVERQUANT_API_KEY=your_quiverquant_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend (email alerts)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Capitol Trades <alerts@yourdomain.com>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron protection for /api/sync-trades
CRON_SECRET=your_random_cron_secret_here

# SEC EDGAR (required User-Agent per SEC policy)
SEC_EDGAR_USER_AGENT=YourApp/1.0 (you@yourdomain.com)
